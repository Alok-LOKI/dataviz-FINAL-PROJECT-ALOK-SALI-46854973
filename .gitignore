# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using tools like pyenv, but of course it's optional
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if the version of python or packages is different
#   between developers, file lock may not be usable.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains specific versions of dependencies
#   and should be committed in a library or app.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains specific versions of dependencies
#   pdm.lock

# virtualenv
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Streamlit config (if you don't want to publish local settings)
.streamlit/config.toml
